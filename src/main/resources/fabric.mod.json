    ]
  },
  "mixins": [],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric": "*",
    "minecraft": "${minecraft_version}",
    "placeholder-api": "*"
  },
  "suggests": {
    "voicechat_api": "*"
  }
}