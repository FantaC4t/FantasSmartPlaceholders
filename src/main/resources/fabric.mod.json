{
  "schemaVersion": 1,
  "id": "playerstatus",
  "version": "${version}",
  "name": "Fanta's Smart Placeholders",
  "description": "Smart placeholders and player features: live status, name colors, roles, no-sleep, and voice chat integration.",
  "authors": [
    "Fantac4t"
  ],
  "contact": {
    "homepage": "https://github.com/fantac4t/FantasSmartPlaceholders",
    "sources":  "https://github.com/fantac4t/FantasSmartPlaceholders",
    "issues":   "https://github.com/fantac4t/FantasSmartPlaceholders/issues"
  },
  "license": "MIT",
  "icon": "assets/playerstatus/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.fantac4t.playerstatus.PlayerStatus"
    ],
    "voicechat": [
      "com.fantac4t.playerstatus.voicechat.PlayerStatusVoicechatPlugin"
    ]
  },
  "mixins": [],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric":       "*",
    "minecraft":    "${minecraft_version}",
    "placeholder-api": "*"
  },
  "suggests": {
    "voicechat_api": "*"
  }
}
