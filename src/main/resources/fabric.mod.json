{
  "schemaVersion": 1,
  "id": "playerstatus",
  "version": "${version}",
  "name": "Fanta's Smart Placeholders",
  "description": "Smart placeholders and player features: live status, name colors, roles, no-sleep, and voice chat integration",
  "authors": [
    "Fantac4t"
  ],
  "contact": {},
  "license": "MIT",
  "icon": "assets/playerstatus/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.fantac4t.playerstatus.PlayerStatus"
    ],
